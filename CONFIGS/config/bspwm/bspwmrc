#! /bin/sh

wmname LG3D
vmware-user-suid-wrapper &

pgrep -x sxhkd > /dev/null || sxhkd &

bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2
bspc config window_gap          12

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true

bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Chromium desktop='^2'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off
bspc rule -a burp-StartBurp state=floating center=true follow=on
bspc rule -a burp state=floating center=true follow=on
bspc rule -a dropdown state=floating sticky=on rectangle=1400x600+260+0

# WALLPAPER
feh --bg-fill "$HOME/Wallpapers/wallpaper.jpg"

# POLYBAR
sleep 1
polybar -q main -c ~/.config/polybar/forest/config.ini &

# CUSTOM
bspc config focus_follows_pointer true
bspc config top_padding 48

# Resolución Full HD (auto-detected by installer)
# xrandr --output Virtual1 --mode 1920x1080
# xrandr --output Virtualbox-0 --mode 1920x1080

# PICOM
picom --no-use-damage -b &
bspc config border_width 0

# NOTIFICATIONS
dunst &

# CLIPBOARD MANAGER
copyq &

# AUTO-LOCK (10 min idle)
xss-lock -- i3lock-color -c 000000 --insidever=282c34 --ringver=61afef --insidewrong=282c34 --ringwrong=e06c75 --inside=282c34 --ring=abb2bf --line=3e4451 --separator=3e4451 --verif-color=61afef --wrong-color=e06c75 --time-color=abb2bf --date-color=abb2bf --layout-color=61afef --keyhl-color=61afef --bshl-color=e06c75 --time-str="%H:%M:%S" --date-str="%A, %d %B %Y" --time-size=40 --date-size=20 --screen 1 --clock --indicator &
xsetroot -cursor_name left_ptr &

# NETWORK APPLET (system tray)
nm-applet &

# REDSHIFT (blue light filter)
redshift -l 4.711:-74.072 -t 5700:3500 &

# CONKY (desktop info)
conky -c ~/.config/conky/conky.conf &
