###############
# ScreenShots #
###############

@Print
        screenshot select

@Print + ctrl
        screenshot

@Print + alt
        screenshot window

# Volume
XF86AudioRaiseVolume
	amixer set Master 5%+
XF86AudioLowerVolume
	amixer set Master 5%-
XF86AudioMute
	amixer set Master toggle
super + F2
	amixer set Master 5%-
super + F3
	amixer set Master 5%+
super + F4
	amixer set Master toggle

# Screen Brightness
XF86MonBrightnessUp
    brightnessctl -c backlight s +10%
XF86MonBrightnessDown
    brightnessctl -c backlight s 10%-

# Keyboard backlight
XF86KbdBrightnessUp
    brightnessctl -d smc::kbd_backlight s +10% 2>/dev/null || true
XF86KbdBrightnessDown
    brightnessctl -d smc::kbd_backlight s 10%- 2>/dev/null || true
